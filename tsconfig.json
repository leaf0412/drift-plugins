{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "paths": {
      "@drift/core": ["../drift/packages/core/src"],
      "@drift/plugins": ["../drift/packages/plugins/src"]
    }
  },
  "include": ["plugins/*/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
